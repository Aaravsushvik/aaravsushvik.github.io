/* =========================
   RESET
   ========================= */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  scroll-behavior: smooth;
}

/* =========================
   BODY
   ========================= */
body {
  font-family: Arial, sans-serif;
  background: #ffffff;
  color: #111111;
  line-height: 1.6;
  transition: 0.4s ease;
}

/* =========================
   DARK MODE
   ========================= */
body.dark {
  background: #111111;
  color: #ffffff;
}

body.dark header {
  background: #000000;
}

body.dark nav ul li a {
  color: #ffffff;
}

body.dark .social a {
  background: #222222;
  color: #ffffff;
}

body.dark input,
body.dark textarea {
  background: #222222;
  color: #ffffff;
  border: 1px solid #555555;
}

/* =========================
   HEADER
   ========================= */
header {
  background: #1f1f1f;
  color: white;
  padding: 25px;
  text-align: center;
  position: sticky;
  top: 0;
  z-index: 1000;
}

header h1 {
  font-size: clamp(22px, 3vw, 36px);
  margin-bottom: 10px;
}

header p {
  margin-bottom: 15px;
}

/* =========================
   TOGGLE BUTTON
   ========================= */
#toggle {
  padding: 10px 20px;
  border: none;
  cursor: pointer;
  border-radius: 8px;
  font-size: 15px;
  margin-bottom: 20px;
}

/* =========================
   NAVIGATION
   ========================= */
nav ul {
  list-style: none;
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 15px;
}

nav ul li a {
  text-decoration: none;
  color: white;
  font-weight: bold;
  transition: 0.3s;
  padding: 10px 14px;
  border-radius: 8px;
}

nav ul li a:hover {
  background: rgba(255,255,255,0.15);
}

/* =========================
   SECTIONS
   ========================= */
section {
  padding: 50px 20px;
  max-width: 1000px;
  margin: auto;
}

h2 {
  margin-bottom: 20px;
  font-size: clamp(22px, 3vw, 32px);
  text-align: center;
}

h3 {
  margin-top: 30px;
  margin-bottom: 15px;
  font-size: clamp(18px, 2.5vw, 24px);
}

p {
  margin-bottom: 20px;
}

/* =========================
   PROFILE IMAGE
   ========================= */
.profile {
  display: block;
  margin: 20px auto;
  width: 220px;
  height: 220px;
  object-fit: cover;
  border-radius: 50%;
  border: 5px solid #333;
  max-width: 90%;
}

/* =========================
   SOCIAL LINKS
   ========================= */
.social {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 15px;
  margin: 25px 0;
}

.social a {
  text-decoration: none;
  background: #f2f2f2;
  padding: 12px 18px;
  border-radius: 10px;
  font-weight: bold;
  color: #111;
  transition: 0.3s;
  display: flex;
  align-items: center;
  gap: 10px;
}

.social a:hover {
  transform: translateY(-3px);
}

/* =========================
   LISTS
   ========================= */
ul, ol {
  margin-left: 25px;
  margin-top: 15px;
}

li {
  margin-bottom: 10px;
}

/* =========================
   DATE STYLE
   ========================= */
.date {
  font-weight: bold;
  color: #666;
}

/* =========================
   FORM
   ========================= */
form {
  display: flex;
  flex-direction: column;
  gap: 15px;
  max-width: 500px;
  margin: auto;
}

input,
textarea {
  padding: 12px;
  border: 1px solid #ccc;
  border-radius: 8px;
  font-size: 16px;
  width: 100%;
}

textarea {
  resize: none;
}

button[type="submit"] {
  padding: 12px;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  font-size: 16px;
  font-weight: bold;
  background: #22c55e;
  color: white;
}

/* =========================
   FOOTER
   ========================= */
footer {
  text-align: center;
  padding: 20px;
  background: #1f1f1f;
  color: white;
  margin-top: 40px;
}

/* =========================
   RESPONSIVE DESIGN
   ========================= */

/* TABLET */
@media (max-width: 1024px) {
  section {
    padding: 40px 15px;
  }
}

/* MOBILE */
@media (max-width: 768px) {

  header h1 {
    font-size: 26px;
  }

  nav ul {
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }

  nav ul li a {
    width: 100%;
    text-align: center;
  }

  .profile {
    width: 170px;
    height: 170px;
  }

  .social {
    flex-direction: column;
  }

  form {
    width: 100%;
    padding: 0 10px;
  }
}

/* SMALL MOBILE */
@media (max-width: 480px) {

  section {
    padding: 30px 12px;
  }

  header {
    padding: 18px;
  }
}