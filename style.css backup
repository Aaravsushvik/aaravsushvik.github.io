/* ── Variables ───────────────────────────────────────────────── */
:root {
    --bg:          #ffffff;
    --text:        #111111;
    --accent:      #0066cc;
    --card-bg:     #f4f4f4;
    --border:      #dddddd;
    --header-height: 80px;
}

html.dark {
    --bg:      #0f0f0f;
    --text:    #f0f0f0;
    --accent:  #4da6ff;
    --card-bg: #1a1a1a;
    --border:  #333333;
}

/* ── Reset / Base ────────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; }

html { scroll-behavior: smooth; }

body {
    margin: 0;
    font-family: 'Poppins', sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.7;
    transition: background 0.3s, color 0.3s;
    -webkit-font-smoothing: antialiased;
}

img, video, iframe { max-width: 100%; height: auto; }

/* ── Accessibility ───────────────────────────────────────────── */
.gotcha { display: none !important; }

.skip-link {
    position: fixed;
    top: -60px;
    left: 10px;
    background: var(--text);
    color: var(--bg);
    padding: 10px 16px;
    z-index: 10000;
    text-decoration: none;
    font-weight: 600;
    border-radius: 0 0 6px 6px;
    transition: top 0.2s;
}
.skip-link:focus { top: 0; }

a:focus-visible,
button:focus-visible,
input:focus-visible,
textarea:focus-visible {
    outline: 3px solid var(--accent);
    outline-offset: 2px;
    border-radius: 4px;
}

@media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
        transition-duration: 0.01ms !important;
        animation-duration: 0.01ms !important;
    }
    html { scroll-behavior: auto; }
}

/* ── Header ──────────────────────────────────────────────────── */
header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 1rem 2rem;
    position: sticky;
    top: 0;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    z-index: 1000;
    min-height: var(--header-height);
    transition: background 0.3s;
}

.header-titles h1 {
    margin: 0;
    font-size: clamp(1.1rem, 3vw, 1.5rem);
}

.header-titles p {
    margin: 0;
    font-size: 0.8rem;
    opacity: 0.7;
}

.header-controls {
    display: flex;
    align-items: center;
    gap: 0.75rem;
}

/* ── Buttons ─────────────────────────────────────────────────── */
#toggle {
    background: transparent;
    color: var(--text);
    border: 1px solid var(--border);
    padding: 7px 12px;
    border-radius: 6px;
    cursor: pointer;
    font-size: 1rem;
    transition: background 0.2s;
}
#toggle:hover { background: var(--card-bg); }

button[type="submit"] {
    background: var(--accent);
    color: #fff;
    border: none;
    padding: 12px 20px;
    border-radius: 6px;
    cursor: pointer;
    font-weight: 600;
    font-family: inherit;
    font-size: 1rem;
    transition: opacity 0.2s;
}
button[type="submit"]:hover { opacity: 0.88; }

/* ── Hamburger ───────────────────────────────────────────────── */
.hamburger {
    display: none;
    background: transparent;
    border: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    padding: 6px;
    color: var(--text);
}

.hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background: currentColor;
    border-radius: 2px;
    transition: background 0.3s;
}

/* ── Navigation ──────────────────────────────────────────────── */
#main-nav ul {
    display: flex;
    list-style: none;
    gap: 1.25rem;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
    justify-content: center;
}

#main-nav a {
    color: var(--text);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.2s;
}
#main-nav a:hover { color: var(--accent); }

/* ── Main content ────────────────────────────────────────────── */
main {
    max-width: 860px;
    margin: 0 auto;
    padding: 1.5rem 2rem;
}

section {
    padding: 3rem 0;
    border-bottom: 1px solid var(--border);
}
section:last-of-type { border-bottom: none; }

h2 {
    margin-top: 0;
    margin-bottom: 1.5rem;
    font-size: clamp(1.3rem, 3vw, 1.8rem);
}
h3 { margin-top: 1.5rem; margin-bottom: 0.5rem; }
p  { margin-bottom: 1rem; }

ul, ol { margin-bottom: 1rem; padding-left: 1.5rem; }
li     { margin-bottom: 0.5rem; }

/* ── Profile image ───────────────────────────────────────────── */
.profile {
    display: block;
    max-width: min(90vw, 380px);
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 12px;
    margin: 0 auto 1.5rem;
    border: 3px solid var(--border);
}

/* ── Social links ────────────────────────────────────────────── */
.social {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
}

.social a {
    color: var(--text);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 8px 14px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--card-bg);
    transition: background 0.2s, transform 0.2s;
}
.social a:hover {
    background: var(--border);
    transform: translateY(-2px);
}

/* ── Authors / description ───────────────────────────────────── */
.authors {
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.55;
    text-align: center;
    margin-bottom: 0.5rem;
}

.description {
    text-align: center;
    max-width: 580px;
    margin: 0 auto 1rem;
    opacity: 0.85;
}

/* ── Project cards ───────────────────────────────────────────── */
.project-card {
    background: var(--card-bg);
    padding: 1.5rem;
    border-radius: 10px;
    margin-bottom: 1.25rem;
    border: 1px solid var(--border);
    transition: background 0.3s, transform 0.2s;
}
.project-card:hover { transform: translateY(-2px); }

.project-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
    gap: 0.5rem;
}
.project-header h3 { margin: 0; font-size: 1rem; }
.project-status {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    opacity: 0.5;
}

/* ── Tag grid ────────────────────────────────────────────────── */
.tag-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 0.5rem;
}

.tag-item {
    background: var(--card-bg);
    padding: 0.45rem 1rem;
    border-radius: 20px;
    font-size: 0.88rem;
    border: 1px solid var(--border);
    transition: background 0.2s;
}

/* ── Results ─────────────────────────────────────────────────── */
.results-summary {
    display: flex;
    gap: 1.25rem;
    margin-top: 0.5rem;
    flex-wrap: wrap;
}

.summary-card {
    background: var(--card-bg);
    padding: 1.5rem 2rem;
    border-radius: 10px;
    border: 1px solid var(--border);
    flex: 1;
    text-align: center;
    min-width: 150px;
    transition: background 0.3s;
}
.summary-card h3 {
    margin: 0 0 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.5;
}
.summary-card p {
    font-size: 2rem;
    font-weight: 700;
    margin: 0;
    letter-spacing: -0.05em;
}

/* ── Form ────────────────────────────────────────────────────── */
form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 520px;
}

label { font-weight: 500; font-size: 0.9rem; }

input, textarea {
    padding: 0.75rem 1rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--card-bg);
    color: var(--text);
    font-family: inherit;
    font-size: 1rem;
    transition: background 0.3s, color 0.3s, border-color 0.3s;
    outline: none;
}
input:focus, textarea:focus { border-color: var(--accent); }
textarea { resize: none; }

/* ── Scroll-to-top ───────────────────────────────────────────── */
#topBtn {
    position: fixed;
    bottom: 24px;
    right: 20px;
    background: var(--text);
    color: var(--bg);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    z-index: 99;
    font-size: 1.1rem;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 1;
    visibility: visible;
    transition: opacity 0.3s, visibility 0.3s, transform 0.2s;
}
#topBtn:hover { transform: translateY(-3px); }
#topBtn.hidden {
    opacity: 0;
    visibility: hidden;
}

/* ── Footer ──────────────────────────────────────────────────── */
footer {
    text-align: center;
    padding: 1.5rem 2rem;
    background: var(--card-bg);
    border-top: 1px solid var(--border);
    font-size: 0.88rem;
    transition: background 0.3s;
}

/* ── Mobile ──────────────────────────────────────────────────── */
@media (max-width: 768px) {
    header { padding: 0.75rem 1.25rem; }

    .header-titles p { display: none; }

    .hamburger { display: flex; }

    #main-nav {
        position: fixed;
        inset: 0;
        top: var(--header-height);
        background: var(--bg);
        display: flex;
        flex-direction: column;
        align-items: center;
        transform: translateX(-100%);
        visibility: hidden;
        transition: transform 0.3s ease, visibility 0.3s ease;
        z-index: 999;
        overflow-y: auto;
        padding: 2rem 0;
    }

    #main-nav.open {
        transform: translateX(0);
        visibility: visible;
    }

    #main-nav ul {
        flex-direction: column;
        align-items: center;
        gap: 1.25rem;
    }

    #main-nav a { font-size: 1.2rem; }

    main { padding: 1rem; }

    .results-summary { flex-direction: column; }

    .social { justify-content: center; }
}

@media (max-width: 480px) {
    section { padding: 2rem 0; }
}
