/* ./assets/css/styles.css */
:root {
    --bg: #ffffff;
    --text: #111111;
    --accent: #0066cc;
    --card-bg: #f4f4f4;
    --border: #dddddd;
    --header-height: 80px;
}

html.dark {
    --bg: #0f0f0f;
    --text: #f0f0f0;
    --accent: #4da6ff;
    --card-bg: #1a1a1a;
    --border: #333333;
}

body {
    margin: 0;
    font-family: 'Poppins', sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    transition: background 0.3s, color 0.3s;
}

/* Accessibility */
.gotcha { 
    display: none !important; 
}

.skip-link {
    position: absolute;
    top: -60px;
    left: 10px;
    background: var(--text);
    color: var(--bg);
    padding: 10px 16px;
    z-index: 10000;
    text-decoration: none;
    font-weight: 600;
    border-radius: 4px;
    transition: top 0.2s;
}

.skip-link:focus {
    top: 10px;
}

a:focus-visible,
button:focus-visible,
input:focus-visible,
textarea:focus-visible {
    outline: 3px solid var(--accent);
    outline-offset: 2px;
    border-radius: 4px;
}

/* Header & Navigation */
header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 2rem;
    position: sticky;
    top: 0;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    z-index: 1000;
    min-height: var(--header-height);
    transition: background 0.3s;
}

.header-titles h1 {
    margin: 0;
    font-size: 1.5rem;
}

.header-titles p {
    margin: 0;
    font-size: 0.85rem;
    color: var(--accent);
}

.header-controls {
    display: flex;
    align-items: center;
    gap: 1rem;
}

#toggle, button[type="submit"] {
    background: var(--accent);
    color: #fff;
    border: none;
    padding: 10px 15px;
    border-radius: 5px;
    cursor: pointer;
    font-weight: 600;
    transition: opacity 0.2s;
}

#toggle:hover, button[type="submit"]:hover {
    opacity: 0.9;
}

.hamburger {
    display: none;
    background: transparent;
    border: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    padding: 5px;
}

.hamburger span {
    display: block;
    width: 25px;
    height: 3px;
    background: var(--text);
    border-radius: 2px;
    transition: background 0.3s;
}

#main-nav ul {
    display: flex;
    list-style: none;
    gap: 1.5rem;
    margin: 0;
    padding: 0;
}

#main-nav a {
    color: var(--text);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.3s;
}

#main-nav a:hover {
    color: var(--accent);
}

/* Main Content area */
main {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem;
}

section {
    padding: 3rem 0;
    border-bottom: 1px solid var(--border);
}

section:last-of-type {
    border-bottom: none;
}

h2 {
    color: var(--accent);
    margin-top: 0;
    margin-bottom: 1.5rem;
}

h3 {
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
}

p {
    margin-bottom: 1rem;
}

ul, ol {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
}

li {
    margin-bottom: 0.5rem;
}

.profile {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin-bottom: 1.5rem;
}

.social {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
}

/* Added Flexbox to format the SVG icons alongside text */
.social a {
    color: var(--accent);
    text-decoration: none;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
}

.social a:hover {
    text-decoration: underline;
}

/* Cards & Grids */
.project-card {
    background: var(--card-bg);
    padding: 1.5rem;
    border-radius: 8px;
    margin-bottom: 1.5rem;
    transition: background 0.3s;
}

.project-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1rem;
    flex-wrap: wrap;
    gap: 0.5rem;
}

.project-header h3 {
    margin: 0;
}

.project-status {
    font-size: 0.85rem;
    opacity: 0.8;
}

.tag-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
}

.tag-item {
    background: var(--card-bg);
    padding: 0.5rem 1rem;
    border-radius: 20px;
    font-size: 0.9rem;
    border: 1px solid var(--border);
    transition: background 0.3s, border-color 0.3s;
}

.results-summary {
    display: flex;
    gap: 1.5rem;
    margin-top: 1rem;
}

.summary-card {
    background: var(--card-bg);
    padding: 1.5rem;
    border-radius: 8px;
    flex: 1;
    text-align: center;
    transition: background 0.3s;
}

.summary-card h3 {
    margin: 0 0 0.5rem 0;
}

.summary-card p {
    font-size: 1.5rem;
    font-weight: bold;
    color: var(--accent);
    margin: 0;
}

/* Forms */
form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 600px;
}

label {
    font-weight: 500;
}

input, textarea {
    padding: 0.75rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    background: var(--bg);
    color: var(--text);
    font-family: inherit;
    font-size: 1rem;
    transition: background 0.3s, color 0.3s, border-color 0.3s;
}

/* Scroll to top button */
#topBtn {
    position: fixed;
    bottom: 20px;
    right: 20px;
    background: var(--accent);
    color: white;
    border: none;
    padding: 10px;
    border-radius: 50%;
    cursor: pointer;
    z-index: 99;
    opacity: 1;
    visibility: visible;
    transition: opacity 0.3s, visibility 0.3s;
    font-size: 1.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 45px;
    height: 45px;
}

#topBtn.hidden {
    opacity: 0;
    visibility: hidden;
}

footer {
    text-align: center;
    padding: 2rem;
    background: var(--card-bg);
    border-top: 1px solid var(--border);
    font-size: 0.9rem;
    transition: background 0.3s, border-color 0.3s;
}

/* Mobile Responsive */
@media (max-width: 768px) {
    .header-titles p {
        display: none;
    }

    .hamburger {
        display: flex;
    }
    
    #main-nav {
        position: fixed;
        top: var(--header-height);
        left: 0;
        right: 0;
        bottom: 0;
        background: var(--bg);
        display: flex;
        flex-direction: column;
        align-items: center;
        transform: translateY(-100%);
        opacity: 0;
        visibility: hidden;
        transition: transform 0.3s ease, opacity 0.3s ease, visibility 0.3s ease;
        z-index: 999;
        overflow-y: auto;
        padding: 2rem 0;
    }
    
    #main-nav.open {
        transform: translateY(0);
        opacity: 1;
        visibility: visible;
    }
    
    #main-nav ul {
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
    }
    
    #main-nav a {
        font-size: 1.25rem;
    }

    .results-summary {
        flex-direction: column;
    }
}
